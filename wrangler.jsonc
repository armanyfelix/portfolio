{
	"compatibility_date": "2026-03-10",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"name": "armany-portfolio",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
