---
import type { Theme } from "@/types/themes";
import themes from "../data/themes.json";
import Menu from "./Menu.astro";

// import { navItems } from "@/config/navItems.data";
// import { MobileMenu } from "./MobileMenu";
// import Button from "../buttons/Button.astro";
// import { t } from "@/lib/utils";

const currentPath = Astro.url.pathname;

let menuOpen = false;
---

<header
    id="navbar"
    class="fixed top-2 left-0 z-50 w-full px-3 duration-500 md:top-3"
>
    <div
        id="nav-wrapper"
        class="mx-auto max-w-full transition-all duration-500"
    >
        <div
            id="nav-container"
            class="relative mx-auto flex w-full items-center justify-between px-4 py-5 transition-all duration-500 md:px-6 lg:px-8 lg:py-8"
        >
            <div class="drawer">
                <input
                    id="menu-drawer"
                    type="checkbox"
                    class="drawer-toggle"
                    onclick={"() => { menuOpen = !menuOpen;}"}
                />
                <div class="drawer-content">
                    <div class={"navbar"}>
                        <div class="navbar-start">
                            <label
                                for="menu-drawer"
                                class={`${menuOpen && "swap-active"} btn btn-lg btn-square btn-ghost drawer-button swap swap-rotate`}
                            >
                                <input type="checkbox" />
                                <svg
                                    class="swap-off fill-current"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width={28}
                                    height={28}
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <title>menu open</title>
                                    <path
                                        stroke-linecap="round"
                                        stroke-line-join="round"
                                        stroke-width="2"
                                        d="M4 6h16M4 12h16M4 18h7"></path>
                                </svg>
                                <svg
                                    class="swap-on fill-current"
                                    xmlns="http://www.w3.org/2000/svg"
                                    width={24}
                                    height={24}
                                    viewBox="0 0 512 512"
                                >
                                    <title>menu close</title>
                                    <polygon
                                        points="400 145.49 366.51 112 256 222.51 145.49 112 112 145.49 222.51 256 112 366.51 145.49 400 256 289.49 366.51 400 400 366.51 289.49 256 400 145.49"
                                    ></polygon>
                                </svg>
                            </label>
                        </div>
                        <div class="navbar-center">
                            <a
                                href="/"
                                id="nav-logo"
                                class="text-primary-content font-boldonse origin-left text-xl font-bold flex items-center tracking-wide uppercase md:text-5xl lg:text-4xl xl:text-5xl"
                                style="will-change: transform;"
                            >
                                Armany felix
                            </a>
                        </div>
                        <div class="navbar-end">
                            <div class="dropdown dropdown-end">
                                <button
                                    type="button"
                                    tab-index={0}
                                    class="btn btn-lg btn-ghost btn-square text-xl"
                                >
                                    <!-- {
                                        themes.find(
                                            (t) => t.name === currentTheme,
                                        )?.emoji || "🎨"
                                    } -->
                                    theme
                                    <svg
                                        width="12px"
                                        height="12px"
                                        class="inline-block h-2 w-2 fill-current opacity-60"
                                        xmlns="http://www.w3.org/2000/svg"
                                        viewBox="0 0 2048 2048"
                                    >
                                        <path
                                            d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"
                                        ></path>
                                    </svg>
                                </button>
                                <ul
                                    tab-index={-1}
                                    class="menu dropdown-content bg-base-300 max-h-[70dvh] overflow-auto flex-nowrap gap-y-2 rounded-box z-1 mt-4 w-60 p-2 shadow-2xl"
                                >
                                    {
                                        themes.map((t: Theme) => (
                                            <li
                                                data-theme={t.name}
                                                class="antialiased rounded-field"
                                            >
                                                <label
                                                    for={`theme-${t.name}`}
                                                    class="theme-controller"
                                                >
                                                    <input
                                                        type="radio"
                                                        name="theme-buttons"
                                                        id={`theme-${t.name}`}
                                                        class={`theme-controller sr-oly`}
                                                        aria-label={t.name}
                                                        value={t.name}
                                                    />
                                                    <div class="text-nowrap">
                                                        {t.emoji} {t.name}
                                                    </div>
                                                    <div class="inline-flex items-center flex-nowrap space-x-1">
                                                        <div class="w-3 h-3 bg-primary rounded-full" />
                                                        <div class="w-3 h-3 bg-secondary rounded-full" />
                                                        <div class="w-3 h-3 bg-accent rounded-full" />
                                                        <div class="w-3 h-3 bg-neutral rounded-full" />
                                                    </div>
                                                </label>
                                            </li>
                                        ))
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- <nav class="hidden gap-1 md:flex lg:gap-3">
                {
                    [{ href: "/", title: "" }].slice(0, -1).map((link) => {
                        const isActive =
                            currentPath === link.href ||
                            (link.href !== "/" &&
                                currentPath.startsWith(link.href));

                        return (
                            <a
                                href={link.href}
                                class={`nav-link font-boldonse text-light uppercase lg:px-8 lg:py-3 ${isActive ? "decoration-orange underline decoration-2 underline-offset-8" : ""}`}
                            >
                                {link.title}
                            </a>
                        );
                    })
                }
                <a href={"/"} class="lg:px-8 lg:py-3"> home </a>
            </nav> -->
                </div>
                <Menu />
            </div>

            <script>
                import gsap from "gsap";

                const navbar = document.getElementById("navbar");
                const navWrapper = document.getElementById("nav-wrapper");
                const navContainer = document.getElementById("nav-container");
                const logo = document.getElementById("nav-logo");

                let isScrolled = false;
                let scrollTween: gsap.core.Tween | null = null;

                if (navbar && navWrapper && navContainer && logo) {
                    const animateToScrolled = () => {
                        if (scrollTween) scrollTween.kill();

                        navWrapper.classList.add(
                            "bg-primary",
                            "shadow-lg",
                            "rounded-box",
                            "border",
                            "border-muted-light/20",
                        );

                        gsap.to(navWrapper, {
                            maxWidth: "96rem",
                            duration: 0.5,
                            ease: "power2.out",
                        });

                        gsap.to(navContainer, {
                            paddingTop: "0.75rem",
                            paddingBottom: "0.75rem",
                            duration: 0.5,
                            ease: "power2.out",
                        });

                        scrollTween = gsap.to(logo, {
                            scale: 0.65,
                            duration: 0.5,
                            ease: "power2.out",
                            transformOrigin: "left center",
                        });
                    };

                    const animateToInitial = () => {
                        if (scrollTween) scrollTween.kill();

                        navWrapper.classList.remove(
                            "bg-primary",
                            "shadow-lg",
                            "rounded-box",
                            "border",
                            "border-muted-light/20",
                        );

                        gsap.to(navWrapper, {
                            maxWidth: "100%",
                            duration: 0.5,
                            ease: "power2.out",
                        });

                        gsap.to(navContainer, {
                            paddingTop:
                                window.innerWidth >= 1024 ? "2rem" : "1.25rem",
                            paddingBottom:
                                window.innerWidth >= 1024 ? "2rem" : "1.25rem",
                            duration: 0.5,
                            ease: "power2.out",
                        });

                        scrollTween = gsap.to(logo, {
                            scale: 1,
                            duration: 0.5,
                            ease: "power2.out",
                            transformOrigin: "left center",
                        });
                    };

                    window.addEventListener("scroll", () => {
                        const shouldBeScrolled = window.scrollY > 50;
                        if (shouldBeScrolled && !isScrolled) {
                            isScrolled = true;
                            animateToScrolled();
                        } else if (!shouldBeScrolled && isScrolled) {
                            isScrolled = false;
                            animateToInitial();
                        }
                    });

                    if (window.scrollY > 50) {
                        isScrolled = true;
                        navWrapper.classList.add(
                            "bg-secondary",
                            "shadow-lg",
                            "rounded-2xl",
                            "border",
                            "border-muted-light/20",
                        );
                        gsap.set(navWrapper, { maxWidth: "96rem" });
                        gsap.set(navContainer, {
                            paddingTop: "0.75rem",
                            paddingBottom: "0.75rem",
                        });
                        gsap.set(logo, {
                            scale: 0.65,
                            transformOrigin: "left center",
                        });
                    }
                }
            </script>

            <script>
                const theme = localStorage.getItem("theme");
                console.log(theme);
                if (!theme) {
                    // if (
                    //     window.matchMedia("(prefers-color-scheme: dark)")
                    //         ?.matches
                    // ) {
                    //     setCurrentTheme("dark");
                    // } else {
                    //     setCurrentTheme("light");
                    // }
                } else {
                    // setCurrentTheme(theme);
                    document.documentElement.setAttribute("data-theme", theme);
                }
                window
                    .matchMedia("(prefers-color-scheme: dark)")
                    .addEventListener("change", (event) => {
                        const newTheme = event.matches ? "dark" : "light";
                        localStorage.setItem("theme", newTheme);
                        // setCurrentTheme(newTheme);
                        document.documentElement.setAttribute(
                            "data-theme",
                            newTheme,
                        );
                    });

                const themeRadios = document.querySelectorAll(
                    'input[name="theme-buttons"]',
                );

                // Define the event handler function
                function handleThemeChange(event: any) {
                    const selectedTheme = event.target.value; // Get the selected value
                    console.log("Selected theme:", selectedTheme);

                    // Example: Apply the theme (e.g., update CSS class)
                    document.body.dataset.theme = selectedTheme;

                    // Example: Save to localStorage
                    localStorage.setItem("preferredTheme", selectedTheme);
                }

                // Attach the "change" event listener to each radio button
                themeRadios.forEach((radio) => {
                    radio.addEventListener("change", handleThemeChange);
                });

                console.log(themeRadios);
            </script>
        </div>
    </div>
</header>
