---
import { products } from "../data/proyects";
import ProductCard from "./ProductCard.astro";

const firstRow = products.slice(0, 3);
const secondRow = products.slice(3, 6);
---

<section
  id="Proyects"
  class="h-[200dvh] relative antialiased flex flex-col perspective-midrange transform-3d"
>
  <!-- <About /> -->
  aboput
  <div class="parallax-container">
    <!-- Primera fila (se mueve a la derecha) -->
    <div class="first-row flex flex-row space-x-10 mb-20">
      {firstRow.map((product) => (
        <ProductCard product={product} key={product.title} />
      ))}
    </div>
    <!-- Segunda fila (se mueve a la izquierda) -->
    <div class="second-row flex flex-row space-x-10 mb-20">
      {secondRow.map((product) => (
        <ProductCard product={product} key={product.title} />
      ))}
    </div>
  </div>
</section>


<style is:global>
  /* Estilos necesarios para las transformaciones 3D y perspectiva */
  .perspective-midrange {
    perspective: 1000px;
  }
  .transform-3d {
    transform-style: preserve-3d;
  }
  /* Las tarjetas usan variables CSS para el desplazamiento horizontal y vertical */
  .product-card {
    transform: translateX(var(--x, 0px)) translateY(var(--y, 0px));
    will-change: transform;
  }
  /* Ajustes de ancho (si no usas Tailwind, define estas clases) */
  .w-100 {
    width: 25rem; /* 400px aprox, ajusta según tu diseño */
  }
  .w-40 {
    width: 10rem; /* 160px aprox */
  }
  .h-80 {
    height: 20rem;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const section = document.getElementById('Proyects');
    if (!section) return;

    const container = document.querySelector('.parallax-container');
    const firstRowCards = document.querySelectorAll('.first-row .product-card');
    const secondRowCards = document.querySelectorAll('.second-row .product-card');
    const allCards = document.querySelectorAll('.product-card');

    // Creamos el ScrollTrigger que actualiza las propiedades según el progreso
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: 'bottom top',
      scrub: true, // Sigue el scroll suavemente
      onUpdate: (self) => {
        const progress = self.progress; // 0 a 1

        // --- Propiedades del contenedor principal (rotate, opacity, translateY) ---
        // Mapeo lineal para cada propiedad en el rango [0, 0.2]
        const rotateXVal = gsap.utils.mapRange(0, 0.2, 25, 0, progress);
        const rotateZVal = gsap.utils.mapRange(0, 0.2, 20, 0, progress);
        const translateYVal = gsap.utils.mapRange(0, 0.2, -590, 400, progress);
        const opacityVal = gsap.utils.mapRange(0, 0.2, 0.2, 1, progress);

        gsap.set(container, {
          rotateX: rotateXVal,
          rotateZ: rotateZVal,
          y: translateYVal,
          opacity: opacityVal,
        });

        // --- Desplazamiento horizontal de las tarjetas (translateX) ---
        // Primera fila: de 0 a 1000 en el rango [0.2, 1]
        const translateXVal = gsap.utils.mapRange(0.2, 1, 0, 1000, progress);
        // Segunda fila: de 150 a -1000 en el rango [0.2, 1]
        const translateXReverseVal = gsap.utils.mapRange(0.2, 1, 150, -1000, progress);

        firstRowCards.forEach(card => {
          gsap.set(card, { '--x': translateXVal + 'px' });
        });

        secondRowCards.forEach(card => {
          gsap.set(card, { '--x': translateXReverseVal + 'px' });
        });
      },
    });

    // --- Efecto hover en las tarjetas (translateY) ---
    allCards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        gsap.to(card, { '--y': '-20px', duration: 0.2, ease: 'power2.out' });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { '--y': '0px', duration: 0.2, ease: 'power2.out' });
      });
    });

    // Limpieza opcional (ScrollTrigger se limpia solo al recargar la página)
    return () => {
      ScrollTrigger.getAll().forEach(st => st.kill());
    };
  });
</script>