<section
    id="proyects"
    class="antialiased relative flex flex-col pb-96 xl:px-30 perspective-midrange transform-3d"
>
    <div class="parallax-container flex flex-row space-x-10 mb-20">
        <div class="horiz-gallery-wrapper">
            <div class="horiz-gallery-strip gap-9">
                {
                    proyects.map((p: any) => (
                        <div
                            class={`product-card ${p.type === "mobile" ? "w-36" : "w-[26vw]"} h-[21vw] box-content shrink-0 group`}
                            data-product-title={p.title}
                        >
                            <a
                                href={p.link}
                                class="block group-hover:shadow-2xl h-full"
                            >
                                <img
                                    src={p.thumbnail}
                                    alt={p.title}
                                    class="object-cover object-center  inset-0 h-full w-full"
                                />
                            </a>
                            <div class="absolute inset-0 h-full w-full opacity-0 group-hover:opacity-80 bg-black pointer-events-none" />
                            <h2 class="absolute bottom-4 left-4 opacity-0 group-hover:opacity-100 text-white">
                                {p.title}
                            </h2>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Estilos necesarios para las transformaciones 3D y perspectiva */
    .perspective-midrange {
        perspective: 1000px;
    }
    .transform-3d {
        transform-style: preserve-3d;
    }
    /* Las tarjetas usan variables CSS para el desplazamiento horizontal y vertical */
    .product-card {
        transform: translateX(var(--x, 0px)) translateY(var(--y, 0px));
        will-change: transform;
    }

    .container-fluid {
        width: 100%;
        padding-right: 0;
        padding-left: 0;
        margin-right: auto;
        margin-left: auto;
    }

    .horiz-gallery-strip,
    .horiz-gallery-wrapper {
        display: flex;
        flex-wrap: wrap;
        will-change: transform;
        position: relative;
        justify-content: center;
    }

    .project-wrap {
        width: 28vw;
        padding: 2rem;
        box-sizing: content-box;
    }
    .project-wrap img {
        width: 100%;
        aspect-ratio: 1/1;
        object-fit: cover;
    }
</style>

<script>
    import gsap from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";
    import ScrollSmoother from "gsap/ScrollSmoother";

    gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

    ScrollSmoother.create({
        wrapper: "#smooth-wrapper",
        content: "#smooth-content",
        smooth: 2,
        normalizeScroll: true,
        ignoreMobileResize: true,
    });

    if (document.getElementById("proyects")) {
        window.addEventListener("load", () => {
            const section = document.getElementById("proyects");
            if (!section) return;

            const container = document.querySelector(".parallax-container");
            // const secondRowCards = document.querySelectorAll(
            //     ".second-row .product-card",
            // );
            // const allCards = document.querySelectorAll(".product-card");

            // --- Valores iniciales (progreso 0) ---
            gsap.set(container, {
                rotateX: 30,
                rotateZ: 20,
                y: -500,
                opacity: 0.1,
            });

            gsap.to(container, {
                scrollTrigger: {
                    trigger: section, // La sección que activa la animación
                    start: "top center", // Cuando el borde superior de la sección toca el borde inferior de la ventana (empieza a entrar)
                    end: "top top", // Cuando el borde superior de la sección llega al borde superior de la ventana (entra completamente)
                    scrub: true, // Suavizado con el scroll
                    // pin: true,
                    // anticipatePin: 1,
                    // markers: true, // Activa para ver los puntos de inicio y fin (útil para depurar)
                },
                rotateX: 0,
                rotateZ: 0,
                y: 50,
                opacity: 1,
                ease: "none",
            });
        });

        //Horizontal Scroll Galleries
        const horizontalSections = gsap.utils.toArray(".horiz-gallery-wrapper");

        horizontalSections.forEach(function (sec: any, i) {
            const pinWrap = sec.querySelector(".horiz-gallery-strip");

            let pinWrapWidth: any;
            // let horizontalScrollLength: any;

            function refresh() {
                pinWrapWidth = pinWrap.scrollWidth;
                // horizontalScrollLength = pinWrapWidth - window.innerWidth;
            }

            refresh();
            // Pinning and horizontal scrolling
            gsap.to(pinWrap, {
                scrollTrigger: {
                    scrub: true,
                    trigger: sec,
                    pin: sec,
                    start: "top top",
                    end: () => `+=${pinWrapWidth}`,
                    invalidateOnRefresh: true,
                    // markers: true,
                },
                // x: () => -horizontalScrollLength,
                x: 700,
                opacity: -1,
                ease: "none",
            });

            ScrollTrigger.addEventListener("refreshInit", refresh);
        });
    }
</script>

