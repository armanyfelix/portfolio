---


const { product } = Astro.props;
---


<div
  class={`product-card ${product.type === 'mobile' ? 'w-40' : 'w-100'} h-80 relative shrink-0 group`}
  data-product-title={product.title}
>
  <a href={product.link} class="block group-hover:shadow-2xl">
    <img
      src={product.thumbnail}
      alt={product.title}
      class="object-cover object-center absolute h-full w-full inset-0"
      width="600"
      height="600"
    />
  </a>
  <div class="absolute inset-0 h-full w-full opacity-0 group-hover:opacity-80 bg-black pointer-events-none"></div>
  <h2 class="absolute bottom-4 left-4 opacity-0 group-hover:opacity-100 text-white">
    {product.title}
  </h2>
</div>